<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>prac.fin</groupId>
    <artifactId>PaymentGateway</artifactId>
    <version>0.0.1-SNAPSHOT</version>
  </parent>
  <artifactId>api</artifactId>
  <packaging>jar</packaging>
  
  <dependencies>
  	 	<!-- All internal modules — this is the assembly point -->
	    <dependency>
	        <groupId>prac.fin</groupId>
	        <artifactId>common</artifactId>
	    </dependency>
	    <dependency>
	        <groupId>prac.fin</groupId>
	        <artifactId>domain</artifactId>
	    </dependency>
	    <dependency>
	        <groupId>prac.fin</groupId>
	        <artifactId>intent-service</artifactId>
	    </dependency>
	    <dependency>
	        <groupId>prac.fin</groupId>
	        <artifactId>session-service</artifactId>
	    </dependency>
	    <dependency>
	        <groupId>prac.fin</groupId>
	        <artifactId>processor-service</artifactId>
	    </dependency>
	    
	    <!-- Web + Validation -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>
        
        <!-- Security : for filter chain setup -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>
        
        <!-- JPA : needed for @EnableJpaAuditing and transaction support -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>
        
        <!-- Redis : session-service uses it, api needs the connection pool -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-redis</artifactId>
        </dependency>
        
        <!-- PostgreSQL driver. Must be on the classpath of the runnable jar -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        
        <!-- Kafka. For publishing payment outcome events -->
        <dependency>
            <groupId>org.springframework.kafka</groupId>
            <artifactId>spring-kafka</artifactId>
        </dependency>
  </dependencies>
  
  <build>
    <plugins>
        <!-- Makes this module the executable Spring Boot fat jar -->
        <plugin>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-maven-plugin</artifactId>
        </plugin>
    </plugins>
  </build>
</project>