<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>prac.fin</groupId>
    <artifactId>PaymentGateway</artifactId>
    <version>0.0.1-SNAPSHOT</version>
  </parent>
  <artifactId>session-service</artifactId>
  <packaging>jar</packaging>
  
  <dependencies>
	 <!--
        Needs common for DTOs, exceptions and SessionStatus enum.
        Does NOT need domain — sessions are stored in Redis, not Postgres.
        This module has no JPA dependency at all.
    -->
    <dependency>
        <groupId>prac.fin</groupId>
        <artifactId>common</artifactId>
    </dependency>
    
    <!-- Redis: where sessions actually live -->
    <dependency>
    	<groupId>org.springframework.boot</groupId>
    	<artifactId>spring-boot-starter-data-redis</artifactId>
    </dependency>
    
     <!-- For @Service, @Component etc. -->
    <dependency>
    	<groupId>org.springframework.boot</groupId>
    	<artifactId>spring-boot-starter</artifactId>
    </dependency>
    
     <!-- Jackson: serialize/deserialize the session object to/from JSON in Redis -->
    <dependency>
        <groupId>com.fasterxml.jackson.core</groupId>
        <artifactId>jackson-databind</artifactId>
    </dependency>
    <dependency>
        <groupId>com.fasterxml.jackson.datatype</groupId>
        <artifactId>jackson-datatype-jsr310</artifactId>
    </dependency>
  </dependencies>
</project>